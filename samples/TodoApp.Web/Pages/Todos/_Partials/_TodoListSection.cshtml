@using TodoApp.Domain.Aggregates.Todos
@model TodoApp.Web.Pages.Todos.IndexModel

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 mt-4 text-sm text-emerald-700">
        @Model.StatusMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 mt-4 text-sm text-rose-700">
        @Model.ErrorMessage
    </div>
}

<section class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <div class="border-b border-stone-100 pb-4">
        <div class="flex items-center justify-between">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-orange-700">Todo List</p>
            <p class="text-sm text-stone-500">
                View: <span class="font-medium text-stone-700">@Model.Filter</span>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <span> | Search: <span class="font-medium text-stone-700">@Model.SearchTerm</span></span>
                }
            </p>
        </div>
    </div>

    @if (Model.TodoList.Items.Count == 0)
    {
        <div class="py-16 text-center">
            <div class="mx-auto max-w-md rounded-3xl border border-dashed border-stone-200 bg-stone-50 px-6 py-10">
                <h3 class="text-lg font-semibold text-stone-900">No todos match this view</h3>
                <p class="mt-3 text-sm leading-6 text-stone-600">Create a new item or switch the active filter to explore more work.</p>
            </div>
        </div>
    }
    else
    {
        <div class="mt-6 space-y-4">
            @foreach (var item in Model.TodoList.Items)
            {
                <article class="rounded-3xl border border-stone-200 bg-stone-50/70 p-5 transition hover:border-stone-300 hover:bg-white">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-center gap-2">
                                <h3 class="text-lg font-semibold text-stone-900">
                                    <a asp-page="/Todos/Details"
                                           asp-route-id="@item.Id"
                                           asp-route-returnFilter="@Model.Filter"
                                           asp-route-returnSearchTerm="@Model.SearchTerm"
                                           class="transition hover:text-orange-700">
                                        @item.Title
                                    </a>
                                    
                                </h3>
                                @if (item.IsPinned)
                                {
                                    <span class="rounded-full bg-orange-100 px-2.5 py-1 text-xs font-medium text-orange-700">Pinned</span>
                                }
                                <div>
                                    <span class="rounded-full px-2.5 py-1 text-xs font-medium @GetPriorityClass(item.Priority)">@GetPriorityText(item.Priority)</span>
                                    <span class="rounded-full px-2.5 py-1 text-xs font-medium @GetStatusClass(item.Status)">@GetStatusText(item.Status)</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="mt-3 text-sm leading-6 text-stone-600">@item.Description</p>
                            }

                            <div class="mt-4 flex flex-wrap gap-2">
                                @if (item.Status == TodoStatus.Active)
                                {
                                    <form method="post" asp-page-handler="Complete" class="inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" asp-for="Filter" />
                                        <input type="hidden" asp-for="SearchTerm" />
                                        <button type="submit" class="rounded-2xl bg-emerald-600 px-3.5 py-2 text-xs font-medium text-white transition hover:bg-emerald-700">
                                            Complete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Reopen" class="inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" asp-for="Filter" />
                                        <input type="hidden" asp-for="SearchTerm" />
                                        <button type="submit" class="rounded-2xl bg-sky-600 px-3.5 py-2 text-xs font-medium text-white transition hover:bg-sky-700">
                                            Reopen
                                        </button>
                                    </form>
                                }

                                <form method="post" asp-page-handler="TogglePin" class="inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" asp-for="Filter" />
                                    <input type="hidden" asp-for="SearchTerm" />
                                    <button type="submit" class="rounded-2xl border border-amber-200 bg-amber-50 px-3.5 py-2 text-xs font-medium text-amber-800 transition hover:bg-amber-100">
                                        @(item.IsPinned ? "Unpin" : "Pin")
                                    </button>
                                </form>

                                <form method="post" asp-page-handler="Delete" class="inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" asp-for="Filter" />
                                    <input type="hidden" asp-for="SearchTerm" />
                                    <button type="submit" class="rounded-2xl border border-rose-200 bg-rose-50 px-3.5 py-2 text-xs font-medium text-rose-700 transition hover:bg-rose-100">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="grid min-w-[220px] gap-2 rounded-2xl bg-white/80 px-4 py-3 text-sm text-stone-500">
                            <div class="flex justify-between gap-4">
                                <span>Due date</span>
                                <span class="font-medium text-stone-700">@(item.DueDate?.ToString("yyyy-MM-dd") ?? "Not set")</span>
                            </div>
                            <div class="flex justify-between gap-4">
                                <span>Completed</span>
                                <span class="font-medium text-stone-700">@(item.CompletedAt?.ToString("yyyy-MM-dd") ?? "-")</span>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@functions {
    private static string GetPriorityText(TodoPriority priority) => priority switch
    {
        TodoPriority.Low => "Low",
        TodoPriority.Medium => "Medium",
        TodoPriority.High => "High",
        TodoPriority.Urgent => "Urgent",
        _ => priority.ToString()
    };

    private static string GetStatusText(TodoStatus status) => status switch
    {
        TodoStatus.Active => "Active",
        TodoStatus.Completed => "Completed",
        _ => status.ToString()
    };

    private static string GetPriorityClass(TodoPriority priority) => priority switch
    {
        TodoPriority.Low => "bg-emerald-50 text-emerald-700",
        TodoPriority.Medium => "bg-amber-50 text-amber-700",
        TodoPriority.High => "bg-orange-50 text-orange-700",
        TodoPriority.Urgent => "bg-rose-50 text-rose-700",
        _ => "bg-stone-100 text-stone-700"
    };

    private static string GetStatusClass(TodoStatus status) => status switch
    {
        TodoStatus.Active => "bg-sky-50 text-sky-700",
        TodoStatus.Completed => "bg-emerald-50 text-emerald-700",
        _ => "bg-stone-100 text-stone-700"
    };
}
