@model TodoApp.Application.Dtos.Todos.TodoStatsDto

<section class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-stone-500">All</p>
            <p class="mt-3 text-3xl font-semibold text-stone-900">@Model.TotalCount</p>
        </article>
        <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-stone-500">Active</p>
            <p class="mt-3 text-3xl font-semibold text-sky-700">@Model.ActiveCount</p>
        </article>
        <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-stone-500">Completed</p>
            <p class="mt-3 text-3xl font-semibold text-emerald-700">@Model.CompletedCount</p>
        </article>
        <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-stone-500">Due today</p>
            <p class="mt-3 text-3xl font-semibold text-orange-700">@Model.DueTodayCount</p>
        </article>
    </div>
</section>
