@model TodoApp.Application.Dtos.Todos.TodoDto

<section class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <div class="border-b border-stone-100 pb-4">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-orange-700">Metadata</p>
    </div>

    <dl class="mt-5 space-y-3 text-sm">
        <div class="rounded-2xl bg-stone-50 px-4 py-3">
            <dt class="text-stone-500">Due date</dt>
            <dd class="mt-1 font-medium text-stone-800">@(Model.DueDate?.ToString("yyyy-MM-dd") ?? "Not set")</dd>
        </div>
        <div class="rounded-2xl bg-stone-50 px-4 py-3">
            <dt class="text-stone-500">Completed</dt>
            <dd class="mt-1 font-medium text-stone-800">@(Model.CompletedAt?.ToString("yyyy-MM-dd") ?? "-")</dd>
        </div>
    </dl>
</section>
