@model TodoApp.Web.Pages.Todos.IndexModel

<aside class="space-y-4">
    <section class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between border-b border-stone-100 pb-4">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-orange-700">Views</p>
            <span class="rounded-full bg-stone-100 px-2.5 py-1 text-xs text-stone-600">@Model.TodoList.Items.Count items</span>
        </div>

        <div class="mt-4 space-y-2">
            @foreach (var filter in Model.Filters)
            {
                var isActive = Model.Filter == filter.Value;
                <a asp-page="/Todos/Index"
                   asp-route-filter="@filter.Value"
                   asp-route-searchTerm="@Model.SearchTerm"
                   class="block rounded-2xl border px-4 py-3 transition @(isActive ? "border-orange-300 bg-orange-50 text-orange-900" : "border-stone-200 bg-stone-50 text-stone-700 hover:border-stone-300 hover:bg-white")">
                    <div class="flex items-center justify-between">
                        <span class="font-medium">@filter.Label</span>
                        @if (isActive)
                        {
                            <span class="rounded-full bg-orange-200 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide">Current</span>
                        }
                    </div>
                    <p class="mt-1 text-xs leading-5 @(isActive ? "text-orange-800/80" : "text-stone-500")">@filter.Description</p>
                </a>
            }
        </div>
    </section>
</aside>
